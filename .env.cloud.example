# Copy to .env.cloud on Alibaba ECS. Never commit the populated file.
MEMORY_DOMAIN=memory.example.com
AGENT_DOMAIN=agent.example.com
ACME_EMAIL=owner@example.com
POSTGRES_DB=mnemagent
POSTGRES_USER=mnemagent
POSTGRES_PASSWORD=replace-with-32-random-characters
MNEMAGENT_API_TOKEN=replace-with-48-random-characters
# Escape each bcrypt dollar as $$ so Compose passes it literally.
OPENCLAW_BASIC_AUTH_HASH=$$2a$$14$$replace-with-caddy-hash
OPENCLAW_IMAGE=replace-with-tested-openclaw-image-and-tag
MNEMOS_DEFAULT_USER_ID=judge-demo
LLM_PROVIDER=openai_compatible
LLM_API_KEY=replace-with-dashscope-key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
QWEN_API_KEY=replace-with-dashscope-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
ALIBABA_CLOUD_OSS_BUCKET=
ALIBABA_CLOUD_OSS_ENDPOINT=
