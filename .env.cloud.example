# Copy to .env.cloud on Alibaba ECS. Never commit the populated file.
MEMORY_DOMAIN=memory.example.com
ACME_EMAIL=owner@example.com
POSTGRES_DB=mnemagent
POSTGRES_USER=mnemagent
POSTGRES_PASSWORD=replace-with-32-random-characters
MNEMAGENT_API_TOKEN=replace-with-48-random-characters
MNEMOS_DEFAULT_USER_ID=judge-demo
LLM_PROVIDER=openai_compatible
LLM_API_KEY=replace-with-dashscope-key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
QWEN_API_KEY=replace-with-dashscope-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
ALIBABA_CLOUD_OSS_BUCKET=
ALIBABA_CLOUD_OSS_ENDPOINT=
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
# MnemCode judge console (generate each secret with: openssl rand -hex 32)
JUDGE_ACCESS_CODE=replace-with-the-private-judge-code
JUDGE_SESSION_SECRET=replace-with-64-random-hex-characters
WORKSPACE_HMAC_SECRET=replace-with-64-random-hex-characters
WORKSPACE_APPROVAL_SECRET=replace-with-64-random-hex-characters
JUDGE_DEMO_REPOSITORY=crankysmh47/MnemAgent-Agent-Lab
JUDGE_GITHUB_TOKEN=github-fine-grained-token-repo-only
JUDGE_RUNNER_IMAGE=mnemagent-judge-runner:2026-07-12
JUDGE_MODEL=openrouter/deepseek/deepseek-v4-flash
JUDGE_MODEL_SOFT_BUDGET_USD=4.25
JUDGE_MODEL_HARD_BUDGET_USD=4.50
OPENROUTER_API_KEY=replace-with-openrouter-key
DOCKER_GID=999
