# Qwen Cloud integration used by MnemAgent
#
# This is Alibaba Cloud Model Studio's international OpenAI-compatible endpoint,
# accepted by the Qwen Global AI Hackathon deployment-proof checklist. Supply
# the API key through the environment; never commit it.

LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
LLM_API_KEY=replace-with-a-dashscope-api-key

# Backward-compatible aliases used by optional Qwen embedding paths.
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_API_KEY=replace-with-a-dashscope-api-key
