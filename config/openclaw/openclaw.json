{
  "gateway": { "mode": "local", "bind": "loopback", "port": 18789, "auth": { "mode": "token", "token": "${OPENCLAW_GATEWAY_TOKEN}" } },
  "models": {
    "mode": "merge",
    "providers": {
      "openrouter": {
        "baseUrl": "https://openrouter.ai/api/v1",
        "api": "openai-completions",
        "apiKey": "${OPENROUTER_API_KEY}",
        "models": [{ "id": "deepseek/deepseek-v4-flash", "name": "DeepSeek V4 Flash", "contextWindow": 128000, "maxTokens": 8192, "input": ["text"], "reasoning": false }]
      }
    }
  },
  "agents": {
    "defaults": { "skipBootstrap": true, "model": { "primary": "openrouter/deepseek/deepseek-v4-flash" } },
    "list": [{
      "id": "judge-coder", "default": true, "name": "MnemCode Judge Coder",
      "workspace": "${OPENCLAW_HOME}/workspace-judge-coder",
      "model": "openrouter/deepseek/deepseek-v4-flash",
      "thinkingDefault": "low",
      "tools": { "profile": "coding", "deny": ["exec", "process", "read", "write", "edit", "apply_patch", "browser", "web_search", "web_fetch"] }
    }]
  },
  "mcp": {
    "servers": {
      "mnemagent": { "url": "http://127.0.0.1:8001/mcp", "transport": "streamable-http", "toolFilter": { "include": ["memory_search", "memory_update"] } },
      "mnemcode": { "command": "node", "args": ["${MNEMCODE_ROOT}/config/openclaw/broker-mcp.js"], "toolFilter": { "include": ["list_issues", "create_workspace", "read_workspace_file", "apply_workspace_patch", "run_workspace_tests", "show_workspace_diff", "cleanup_workspace"] } }
    }
  }
}
