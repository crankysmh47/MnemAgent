# MnemOS environment configuration
# Copy this file to .env and fill in your values.
#
#   cp config/env.template .env
#
# Never commit .env. It is ignored by git and Docker.

# === LLM API ================================================================
#
# MnemOS supports two API styles:
#
#   LLM_PROVIDER=openai_compatible
#     Works with DashScope compatible mode, OpenRouter, DeepSeek, OpenAI, and
#     most providers that expose /chat/completions.
#
#   LLM_PROVIDER=anthropic
#     Works with Anthropic's /v1/messages API.
#
# OpenAI-compatible examples:
#
# DashScope / Alibaba Cloud:
#   LLM_PROVIDER=openai_compatible
#   LLM_API_KEY=sk-...
#   LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   LLM_MODEL=qwen-flash
#
# Alibaba Cloud Workspace:
#   LLM_PROVIDER=openai_compatible
#   LLM_API_KEY=sk-ws-...
#   LLM_BASE_URL=https://ws-<workspace-id>.<region>.maas.aliyuncs.com/compatible-mode/v1
#   LLM_MODEL=qwen-flash
#
# OpenRouter:
#   LLM_PROVIDER=openai_compatible
#   LLM_API_KEY=sk-or-v1-...
#   LLM_BASE_URL=https://openrouter.ai/api/v1
#   LLM_MODEL=deepseek/deepseek-chat-v3.1:free
#   LLM_MODEL=qwen/qwen3-235b-a22b:free
#
# DeepSeek direct:
#   LLM_PROVIDER=openai_compatible
#   LLM_API_KEY=sk-...
#   LLM_BASE_URL=https://api.deepseek.com
#   LLM_MODEL=deepseek-chat
#
# Anthropic / Claude:
#   LLM_PROVIDER=anthropic
#   ANTHROPIC_API_KEY=sk-ant-...
#   LLM_MODEL=claude-sonnet-4-20250514

LLM_PROVIDER=openai_compatible
LLM_API_KEY=sk-xxxxxxxxxxxx
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-flash

# Backward-compatible aliases for older scripts and optional Qwen embeddings.
# Keep these aligned with LLM_* unless you intentionally use a separate Qwen
# embedding endpoint.
QWEN_API_KEY=sk-xxxxxxxxxxxx
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-flash

# Anthropic-only settings. Used when LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_VERSION=2023-06-01

# Judge/live namespace. Leave blank during development; reset scripts write a
# fresh judge-* value before deployment so test memories cannot leak.
MNEMOS_DEFAULT_USER_ID=

# Dreaming-phase fallback when dual-output tags are missing.
ENABLE_DREAMING_EXTRACTION=true

# Wait for memory writes before returning /chat response.
AWAIT_DREAMING=true
EXTRACTION_MIN_CONVICTION=0.4

# Optional. Leave empty to use LLM_MODEL. For DashScope demos, qwen-turbo is a
# cost-effective extraction model.
EXTRACTION_MODEL=

# === Retrieval tuning =======================================================
SEMANTIC_SIMILARITY_FLOOR=0.3
CHAT_MAX_TOKENS=2000

# === Alibaba Cloud OSS (optional backup) ===================================
# MnemOS snapshots memory_state.db to OSS every 50 turns when credentials are
# set. Leave placeholders to skip cloud sync.
ALIBABA_CLOUD_ACCESS_KEY_ID=xxxxxxxxxxxx
ALIBABA_CLOUD_ACCESS_KEY_SECRET=xxxxxxxxxxxx
ALIBABA_CLOUD_OSS_BUCKET=mnemos-backups
ALIBABA_CLOUD_OSS_ENDPOINT=https://oss-ap-southeast-1.aliyuncs.com

# === Embedding (local sentence-transformers by default) =====================
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# Optional: Qwen cloud embeddings. Requires QWEN_* values above.
# EMBEDDING_MODEL=text-embedding-v3
# EMBEDDING_DIM=1024

# === MnemOS memory tuning ===================================================
UCB_EXPLORATION_C=0.3
RWR_ALPHA=0.85
RWR_MIN_NODES=15
DECAY_RATE=0.85
PRUNE_THRESHOLD=0.1
MAX_INJECTED_FACTS=6

# === Server (FastAPI via uvicorn) ==========================================
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
# Docker sets DB_PATH=/app/data/memory_state.db in docker-compose.yml.

# === MCP server =============================================================
MCP_PORT=8001
MCP_ADAPTER_PORT=8001
OPENCLAW_CONFIG_DIR=~/.openclaw

# === OpenClaw channel tokens (optional) ====================================
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=
# SLACK_APP_TOKEN=
# SLACK_BOT_TOKEN=

# === Visualizer =============================================================
VISUALIZER_POLL_INTERVAL=3000
EVENT_RETENTION_HOURS=24
