# =============================================================================
# MnemOS Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp config/env.template .env
#
# NEVER commit .env — it is in .gitignore and .dockerignore.
# =============================================================================

# === LLM API (Required — OpenAI-compatible chat/completions) ===
#
# ── DashScope (Alibaba Cloud — recommended for production) ──────────────────
# Fast, reliable, hackathon target. Get key at https://dashscope.aliyuncs.com
#   QWEN_API_KEY=sk-...
#   QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   QWEN_MODEL=qwen-flash        # cheapest usable
#   QWEN_MODEL=qwen-turbo        # good balance
#   QWEN_MODEL=qwen-plus         # better quality
#   QWEN_MODEL=qwen-max          # best quality (demos, eval)
#
# ── Alibaba Cloud Workspace (Singapore free trial — 1M tokens) ─────────────
#   QWEN_API_KEY=sk-ws-...
#   QWEN_BASE_URL=https://ws-<workspace-id>.<region>.maas.aliyuncs.com/compatible-mode/v1
#   QWEN_MODEL=qwen-flash
#
# ── OpenRouter (development only — free models stall 2-6 min/reply) ────────
#   QWEN_API_KEY=sk-or-v1-...
#   QWEN_BASE_URL=https://openrouter.ai/api/v1
#   QWEN_MODEL=qwen/qwen-2.5-72b-instruct:free
#   QWEN_MODEL=deepseek/deepseek-r1-0528:free
#   QWEN_MODEL=meta-llama/llama-3.3-70b-instruct:free
#
# =============================================================================

QWEN_API_KEY=sk-or-v1-xxxxxxxxxxxx
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-flash

# Dreaming-phase fallback when dual-output tags are missing (default: true)
ENABLE_DREAMING_EXTRACTION=true
# Wait for memory writes before returning /chat response (default: true)
AWAIT_DREAMING=true
EXTRACTION_MIN_CONVICTION=0.4
EXTRACTION_MODEL=qwen-turbo

# === Retrieval tuning ===
SEMANTIC_SIMILARITY_FLOOR=0.3
CHAT_MAX_TOKENS=2000

# === Alibaba Cloud OSS (cloud backup — optional) ============================
# MnemOS snapshots memory_state.db to OSS every 50 turns when credentials are set.
# Leave as placeholder to skip cloud sync.
ALIBABA_CLOUD_ACCESS_KEY_ID=xxxxxxxxxxxx
ALIBABA_CLOUD_ACCESS_KEY_SECRET=xxxxxxxxxxxx
ALIBABA_CLOUD_OSS_BUCKET=mnemos-backups
ALIBABA_CLOUD_OSS_ENDPOINT=https://oss-ap-southeast-1.aliyuncs.com

# === Embedding (local sentence-transformers) ===
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384
# Optional: Qwen cloud embeddings (requires API key, faster in Alibaba Cloud)
# EMBEDDING_MODEL=text-embedding-v3
# EMBEDDING_DIM=1024

# === MnemOS Memory Tuning ===
UCB_EXPLORATION_C=0.3
RWR_ALPHA=0.85
RWR_MIN_NODES=15
DECAY_RATE=0.85
PRUNE_THRESHOLD=0.1
MAX_INJECTED_FACTS=6

# === Server (FastAPI via uvicorn) ===
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
# Docker: set DB_PATH=/app/data/memory_state.db (see docker-compose.yml)

# === MCP Server ===
MCP_PORT=8001
MCP_ADAPTER_PORT=8001
OPENCLAW_CONFIG_DIR=~/.openclaw

# === OpenClaw channel tokens (optional — enable in config/openclaw/openclaw.json) ===
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=
# SLACK_APP_TOKEN=
# SLACK_BOT_TOKEN=

# === Visualizer ===
VISUALIZER_POLL_INTERVAL=3000
EVENT_RETENTION_HOURS=24
