# === LLM API (OpenAI-compatible chat/completions) ===
#
# Get a free API key at https://openrouter.ai/keys
# Then set QWEN_API_KEY below.
#
# ── Model Tiers (set QWEN_MODEL) ─────────────────────────────────────────
#   qwen-turbo     Cheapest, fastest  — good for daily use, prototyping
#   qwen-plus      Balanced           — moderate cost, solid quality
#   qwen-max       Best quality       — use for demos, evaluations
#
# ── Free Tier (OpenRouter) ────────────────────────────────────────────────
# The config/openclaw/free-models.patch.json bundles free OpenRouter models
# (DeepSeek R1, Qwen 2.5, Llama 3.3, etc.) as fallbacks. Set QWEN_MODEL to
# any OpenRouter free model ID, e.g.:
#   deepseek/deepseek-r1-0528:free
#   qwen/qwen-2.5-72b-instruct:free
#   meta-llama/llama-3.3-70b-instruct:free
#
# ── Production (DashScope Qwen) ───────────────────────────────────────────
# Best extraction compliance for live eval. Requires Alibaba Cloud API key.
#   QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   QWEN_MODEL=qwen-max
#   EXTRACTION_MODEL=qwen-turbo
#
# =========================================================================

# OpenRouter (FREE tier — recommended for getting started)
QWEN_API_KEY=sk-or-v1-xxxxxxxxxxxx
QWEN_BASE_URL=https://openrouter.ai/api/v1
QWEN_MODEL=deepseek/deepseek-r1-0528:free
# QWEN_MODEL=qwen/qwen-2.5-72b-instruct:free
# QWEN_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Dreaming-phase fallback when dual-output tags are missing (default: true)
ENABLE_DREAMING_EXTRACTION=true
EXTRACTION_MIN_CONVICTION=0.4

# === Alibaba Cloud OSS (proof artifact — optional) ===
ALIBABA_CLOUD_ACCESS_KEY_ID=xxxxxxxxxxxx
ALIBABA_CLOUD_ACCESS_KEY_SECRET=xxxxxxxxxxxx
ALIBABA_CLOUD_OSS_BUCKET=mnemos-backups
ALIBABA_CLOUD_OSS_ENDPOINT=https://oss-ap-southeast-1.aliyuncs.com

# === Embedding (local by default) ===
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384
# Optional: uncomment for Qwen cloud embeddings (requires API key)
# EMBEDDING_MODEL=text-embedding-v3
# EMBEDDING_DIM=1024

# === MnemOS Tuning ===
UCB_EXPLORATION_C=0.3
RWR_ALPHA=0.85
RWR_MIN_NODES=15
DECAY_RATE=0.85
PRUNE_THRESHOLD=0.1
MAX_INJECTED_FACTS=6

# === Server ===
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
# Docker: set DB_PATH=/app/data/memory_state.db (see docker-compose.yml)

# MCP Server
MCP_PORT=8001
MCP_ADAPTER_PORT=8001
OPENCLAW_CONFIG_DIR=~/.openclaw

# OpenClaw channel tokens (optional — enable in config/openclaw/openclaw.json)
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=
# SLACK_APP_TOKEN=
# SLACK_BOT_TOKEN=

# Visualizer
VISUALIZER_POLL_INTERVAL=3000
EVENT_RETENTION_HOURS=24
