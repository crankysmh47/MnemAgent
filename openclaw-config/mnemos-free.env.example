# MnemOS + OpenClaw — OpenRouter FREE tier (copy values into .env)
# Get a key at https://openrouter.ai/keys (free tier, no card required for many models)

QWEN_API_KEY=sk-or-v1-xxxxxxxxxxxx
QWEN_BASE_URL=https://openrouter.ai/api/v1

# MnemOS backend chat (no tool calling required — any free chat model works)
# Primary: DeepSeek R1 reasoning. Fallbacks tried by you swapping QWEN_MODEL if rate-limited.
QWEN_MODEL=deepseek/deepseek-r1-0528:free

# Alternatives (set QWEN_MODEL to one of these):
# QWEN_MODEL=deepseek/deepseek-r1:free
# QWEN_MODEL=qwen/qwen-2.5-72b-instruct:free
# QWEN_MODEL=meta-llama/llama-3.3-70b-instruct:free
# QWEN_MODEL=google/gemma-2-9b-it:free

# OpenClaw agent MCP tools use openclaw-config/free-models.patch.json
# (primary: openrouter/free router, fallbacks: R1, Llama, Qwen free variants)
