# === LLM API (OpenAI-compatible chat/completions) ===
# Production (DashScope Qwen):
# QWEN_API_KEY=sk-xxxxxxxxxxxx
# QWEN_MODEL=qwen-plus
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#
# Temporary dev/testing (OpenRouter — any OpenAI-compatible provider):
QWEN_API_KEY=sk-or-v1-xxxxxxxxxxxx
QWEN_MODEL=qwen/qwen-2.5-7b-instruct
QWEN_BASE_URL=https://openrouter.ai/api/v1

# === Alibaba Cloud OSS (proof artifact) ===
ALIBABA_CLOUD_ACCESS_KEY_ID=xxxxxxxxxxxx
ALIBABA_CLOUD_ACCESS_KEY_SECRET=xxxxxxxxxxxx
ALIBABA_CLOUD_OSS_BUCKET=mnemos-backups
ALIBABA_CLOUD_OSS_ENDPOINT=https://oss-ap-southeast-1.aliyuncs.com

# === Embedding (local by default — see MASTERPLAN Part 0.5.4) ===
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384
# Optional upgrade: uncomment for Qwen cloud embeddings (requires API key)
# EMBEDDING_MODEL=text-embedding-v3
# EMBEDDING_DIM=1024

# === MnemOS Tuning ===
UCB_EXPLORATION_C=0.3
RWR_ALPHA=0.85
RWR_MIN_NODES=15
DECAY_RATE=0.85
PRUNE_THRESHOLD=0.1
MAX_INJECTED_FACTS=6

# === Server ===
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
# Docker: set DB_PATH=/app/data/memory_state.db (see docker-compose.yml)
